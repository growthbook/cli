# GrowthBook CLI — local iteration env. Copy to .env.local and fill in real values.
# .env.local is gitignored; this template is committed.
#
# Load before running the CLI:
#   set -a && source .env.local && set +a
# Then point the CLI at your local back-end with --server-url (see note below):
#   ./growthbook projects list --server-url "$GB_SERVER_URL"

# --- Auth (read natively by the CLI from the GBCLI_ prefix) ---
# Generate a Secret Key or Personal Access Token in your LOCAL instance
# (Settings -> API Keys). Bearer is simplest; Basic-auth alts are below.
GBCLI_BEARER_AUTH=secret_REPLACE_ME
# GBCLI_USERNAME=secret_REPLACE_ME   # HTTP Basic: Secret Key as username...
# GBCLI_PASSWORD=                    # ...with an empty password

# --- Server (NOT read from env by the CLI — auth is the only env-mapped group) ---
# Pass this value explicitly via --server-url. We override the full URL because the
# CLI's indexed self-hosted server forces https://{domain}/api, which won't reach a
# plain-http local back-end. Default back-end port is 3100.
GB_SERVER_URL=http://localhost:3100/api
