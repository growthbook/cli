# .gitignore
.DS_Store
**/.speakeasy/temp/
**/.speakeasy/logs/
.speakeasy/reports
.env
.env.local
dist/
# Built CLI binary (regenerate with: go build -o growthbook ./cmd/growthbook)
/growthbook
# generate-types default output (user artifact, not repo content)
/growthbook-types/
