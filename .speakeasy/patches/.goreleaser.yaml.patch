diff --git a/.goreleaser.yaml b/.goreleaser.yaml
--- a/.goreleaser.yaml
+++ b/.goreleaser.yaml
@@ -1,6 +1,11 @@
 # yaml-language-server: $schema=https://goreleaser.com/static/schema.json
 version: 2
 
+# The archive name_template uses {{ .ProjectName }}; without this it defaults to
+# the repo name ("cli"), producing cli_<Os>_<arch> archives. The npm shim
+# (npm/lib/platform.js) downloads growthbook_<Os>_<arch>, so pin the name.
+project_name: growthbook
+
 before:
   hooks:
     - go mod tidy
@@ -22,6 +27,12 @@ builds:
       - -s -w
       - -X main.version={{.Version}}
       - -X main.buildTime={{.Date}}
+      # Update/compat advisory build metadata (internal/customcfg). Version is
+      # required for the semver check; SpecDate (the spec's commit date, computed
+      # in CI) is the orderable compatibility signal.
+      - -X github.com/growthbook/cli/internal/customcfg.Version={{.Version}}
+      - -X github.com/growthbook/cli/internal/customcfg.Commit={{.ShortCommit}}
+      - -X github.com/growthbook/cli/internal/customcfg.SpecDate={{.Env.GB_SPEC_DATE}}
 
 archives:
   - id: growthbook
@@ -47,6 +58,34 @@ release:
   draft: false
   prerelease: auto
   mode: append
+  # Publish the generated-against date so a running CLI can read it back (via the
+  # GitHub API) and decide whether a newer CLI is compatible with the user's
+  # backend. Machine-read by internal/customcfg.parseSpecDate; the HTML comment
+  # keeps it out of the rendered notes.
+  footer: |
+    <!-- gb-spec-date: {{ .Env.GB_SPEC_DATE }} -->
+
 
 checksum:
   name_template: "checksums.txt"
+
+# Publish a Homebrew cask to growthbook/homebrew-tap. skip_upload: auto keeps
+# prerelease (-next) tags out of the tap; the post-install hook strips the
+# Gatekeeper quarantine attribute since the darwin binaries are unsigned.
+homebrew_casks:
+  - name: growthbook
+    repository:
+      owner: growthbook
+      name: homebrew-tap
+      token: "{{ .Env.HOMEBREW_TAP_TOKEN }}"
+    directory: Casks
+    homepage: https://docs.growthbook.io/tools/cli
+    description: Command-line interface for GrowthBook feature flags and experiments
+    skip_upload: auto
+    commit_msg_template: "growthbook {{ .Tag }}"
+    hooks:
+      post:
+        install: |
+          if OS.mac?
+            system_command "/usr/bin/xattr", args: ["-dr", "com.apple.quarantine", "#{staged_path}/growthbook"]
+          end
