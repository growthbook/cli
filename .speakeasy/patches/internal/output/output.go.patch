+// displayedError marks an error that Error has already printed to stderr, so
+// the top-level runner (cmd/growthbook) knows not to print it a second time.
+type displayedError struct{ error }
+
+func (d displayedError) Unwrap() error { return d.error }
+
+// IsDisplayed reports whether err was already surfaced to the user by Error.
+func IsDisplayed(err error) bool {
+	var d displayedError
+	return errors.As(err, &d)
+}
