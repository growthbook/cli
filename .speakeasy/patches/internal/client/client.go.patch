+
+// credentialSourceRank orders credential sources by the resolution priority
+// flag > env > keyring > config, so schemes can be compared across each other.
+func credentialSourceRank(source string) int {
+	switch source {
+	case "flag":
+		return 4
+	case "env":
+		return 3
+	case "keyring":
+		return 2
+	case "config":
+		return 1
+	default:
+		return 0
+	}
+}
