diff --git a/cmd/growthbook/main.go b/cmd/growthbook/main.go
--- a/cmd/growthbook/main.go
+++ b/cmd/growthbook/main.go
@@ -7,6 +7,7 @@ import (
 	"os"
 
 	"github.com/growthbook/cli/internal/cli"
+	"github.com/growthbook/cli/internal/output"
 )
 
 // version and buildTime can be set at build time using Go linker flags:
@@ -24,7 +25,11 @@ func main() {
 	}
 
 	if err := cli.Execute(); err != nil {
-		fmt.Fprintln(os.Stderr, err)
+		// output.Error already prints a formatted message for the errors it
